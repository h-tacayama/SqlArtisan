<Project>

  <!--
    Exposes the consumer's <SqlArtisanTargetDbms> and <SqlArtisanTargetVersion>
    MSBuild properties to the bundled analyzer (#93 / #262) as
    build_property.SqlArtisanTargetDbms / build_property.SqlArtisanTargetVersion.
    These are alternatives to the primary .editorconfig keys
    (sqlartisan_target_dbms / sqlartisan_target_version) for projects that
    prefer setting the target in a .csproj / Directory.Build.props instead —
    the analyzer's config resolver checks both.
  -->
  <ItemGroup>
    <CompilerVisibleProperty Include="SqlArtisanTargetDbms" />
    <CompilerVisibleProperty Include="SqlArtisanTargetVersion" />
  </ItemGroup>

</Project>
